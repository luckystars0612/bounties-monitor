# ── Required ───────────────────────────────────────────────────────────────────
# Telegram Bot Token — get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Telegram Chat ID — message @userinfobot to find yours
# Can be a personal chat ID or a group chat ID (negative number)
TELEGRAM_CHAT_ID=

# ── Optional: GitHub Token ─────────────────────────────────────────────────────
# Without a token: 60 unauthenticated requests/hour (more than enough for hourly checks)
# With a token:    5,000 requests/hour
# Generate one at: https://github.com/settings/tokens (no scopes needed for public repos)
# GITHUB_TOKEN=

# ── Polling ────────────────────────────────────────────────────────────────────
# Check interval in minutes. The upstream data source updates hourly, so 60 is ideal.
POLL_INTERVAL_MINUTES=60

# ── Platforms ──────────────────────────────────────────────────────────────────
# Comma-separated. Supported: hackerone, bugcrowd, intigriti, yeswehack
ENABLED_PLATFORMS=hackerone,bugcrowd,intigriti,yeswehack

# ── Notification filters ───────────────────────────────────────────────────────
# Which change types to notify about. Options:
#   new_scope        — a new in-scope target was added
#   removed_scope    — an in-scope target was removed
#   new_program      — a brand-new bug bounty program appeared
#   bounty_increase  — max payout was raised
#   bounty_decrease  — max payout was lowered
NOTIFY_ON=new_scope,new_program,bounty_increase,removed_scope

# ── Filter VDP Programs ────────────────────────────────────────────────────────
# If set to true, VDP programs (without cash payouts) are completely skipped.
# Only programs offering active monetary bounties will trigger database updates and alerts.
BOUNTIES_ONLY=false

# ── Storage ────────────────────────────────────────────────────────────────────
DATABASE_PATH=bounties_monitor.db

# ── HTTP ───────────────────────────────────────────────────────────────────────
REQUEST_TIMEOUT=30
MAX_RETRIES=3
